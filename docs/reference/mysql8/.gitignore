# =====================================================================
# mysql8 코스 .gitignore
# =====================================================================

# Step 23 백업 실습 산출물 — 덤프 파일은 용량이 크고 데이터라 커밋하지 않는다.
# backup-restore.sh 를 실행하면 언제든 다시 생성된다.
backup/*.sql
backup/*.sql.gz
backup/*.dump

# mysqlsh dump-utility 산출물 디렉터리
backup/dump-*/

# 임시/로그
*.log
.DS_Store
