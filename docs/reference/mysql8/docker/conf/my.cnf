[mysqld]
# ─────────────────────────────────────────────────────────────
# 학습용 MySQL 8 설정. 운영 설정이 아니라 "관찰하기 좋은" 설정입니다.
# ─────────────────────────────────────────────────────────────

# 문자셋 / 콜레이션
character_set_server = utf8mb4
collation_server     = utf8mb4_0900_ai_ci

# 타임존 (Step 12 날짜 함수 실습에서 확인)
default_time_zone = '+09:00'

# InnoDB 버퍼 풀: 학습용이라 작게. 운영에서는 물리 메모리의 50~70%.
innodb_buffer_pool_size = 256M

# 슬로우 쿼리 로그 (Step 24에서 사용)
slow_query_log       = 1
slow_query_log_file  = /var/lib/mysql/slow.log
long_query_time      = 0.5
log_queries_not_using_indexes = 1

# 일반 쿼리 로그는 기본 OFF (필요할 때 Step 24에서 동적으로 켭니다)
general_log = 0

# 이벤트 스케줄러 (Step 20 EVENT 실습)
event_scheduler = ON

# LOAD DATA LOCAL INFILE 허용 (Step 03 대량 적재 실습)
local_infile = 1

# sql_mode: 8.0 기본값을 그대로 사용 (STRICT_TRANS_TABLES, ONLY_FULL_GROUP_BY 포함)
# 일부러 끄지 않습니다. Step 06에서 ONLY_FULL_GROUP_BY 를 직접 겪어봐야 하기 때문입니다.
sql_mode = ONLY_FULL_GROUP_BY,STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION

[client]
default-character-set = utf8mb4
